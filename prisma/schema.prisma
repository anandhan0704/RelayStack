generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at")
  apiKeys   ApiKey[]
  wallet    Wallet?
  messages  Message[]

  @@map("customers")
}

model ApiKey {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  name       String
  keyHash    String   @unique @map("key_hash")
  preview    String
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("api_keys")
}

model Wallet {
  id           String              @id @default(uuid())
  customerId   String              @unique @map("customer_id")
  balance      Decimal             @db.Decimal(12, 4)
  currency     String              @default("USD")
  customer     Customer            @relation(fields: [customerId], references: [id])
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String   @map("wallet_id")
  amount      Decimal  @db.Decimal(12, 4)
  type        String
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")
  wallet      Wallet   @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("wallet_transactions")
}

model Message {
  id                String               @id @default(uuid())
  customerId        String               @map("customer_id")
  channel           String
  fromAddress       String               @map("from_address")
  toAddress         String               @map("to_address")
  subject           String?
  body              String
  status            String
  provider          String
  providerMessageId String?              @map("provider_message_id")
  cost              Decimal              @db.Decimal(12, 4)
  callbackUrl       String?              @map("callback_url")
  createdAt         DateTime             @default(now()) @map("created_at")
  customer          Customer             @relation(fields: [customerId], references: [id])
  statusEvents      MessageStatusEvent[]

  @@index([customerId, createdAt])
  @@map("messages")
}

model MessageStatusEvent {
  id         String   @id @default(uuid())
  messageId  String   @map("message_id")
  status     String
  rawPayload Json?    @map("raw_payload")
  createdAt  DateTime @default(now()) @map("created_at")
  message    Message  @relation(fields: [messageId], references: [id])

  @@index([messageId])
  @@map("message_status_events")
}

model ProviderRoute {
  id        String   @id @default(uuid())
  name      String
  channel   String
  country   String
  health    String   @default("healthy")
  unitCost  Decimal  @db.Decimal(12, 4) @map("unit_cost")
  priority  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("provider_routes")
}

model ComplianceApproval {
  id           String   @id @default(uuid())
  customerName String   @map("customer_name")
  type         String
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("compliance_approvals")
}
